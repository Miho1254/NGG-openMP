# ===================================
# SA-MP / Open.MP Server .gitignore
# ===================================

# ----- Compiled Binaries (Pawn) -----
*.amx
*.ASM

# ----- Native Libraries / DLLs -----
*.dll
*.so
*.pdb
*.dmp

# ----- Executables -----
*.exe
samp-server.exe
samp-npc.exe
omp-server.exe
omp-server.pdb
omp_minidump.dmp
announce.exe

# ----- Compiler / IDE -----
pawno/
qawno/

# ----- Server Runtime / Config -----
config.json
server_log.txt
server-readme.txt
samp-license.txt
crashinfo.txt
log.txt
log-core.dll

# ----- Logs -----
logs/
scriptfiles/*.log
scriptfiles/logs/

# ----- Database Files -----
*.db
*.sqlite
*.sqlite3

# ----- Backup -----
backup/

# ----- Server Binaries (OMP Components) -----
components/

# ----- Plugins (Third-party binaries) -----
plugins/

# ----- MSVC Runtime -----
msvcp*.dll
msvcr*.dll
libmysql.dll
libmariadb.dll
pawncmd.dll

# ----- Models / NPC Recordings -----
models/
npcmodes/recordings/

# ----- Scriptfiles (Runtime Data) -----
scriptfiles/IPList.db
scriptfiles/projects.db
scriptfiles/logs.db
scriptfiles/cardealerships.json
scriptfiles/bans.json

# ----- OS / Editor -----
Thumbs.db
Desktop.ini
.DS_Store
*.swp
*.swo
*~
.vscode/
.idea/
*.sublime-workspace
*.sublime-project

# ----- Temporary / Old Files -----
*.old
*.bak
*.tmp
*.temp
*.orig

# ----- Not Used / Deprecated -----
gamemodes/not used/
gamemodes/includes/bangxephang KAII.pwn
